{
  "name": "axiom-foundation",
  "private": true,
  "workspaces": ["packages/*"],
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "build:ui": "bun run --cwd packages/ui build",
    "dev": "bun run build:ui && next dev --turbopack",
    "build": "bun run build:ui && next build",
    "start": "next start",
    "test": "bun run build:ui && vitest",
    "test:run": "bun run build:ui && vitest run",
    "test:coverage": "bun run build:ui && vitest run --coverage",
    "deploy": "vercel --prod"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.90.1",
    "geist": "^1.7.0",
    "motion": "^12.0.0",
    "next": "^16",
    "posthog-js": "^1.360.1",
    "prismjs": "^1.30.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/coverage-v8": "2.1.9",
    "jsdom": "^26.0.0",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.6.0",
    "vitest": "^2.0.0"
  }
}
