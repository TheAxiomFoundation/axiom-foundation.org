{
  "name": "@axiom-foundation/ui",
  "version": "0.1.3",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tokens.css": "./dist/styles/tokens.css",
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheAxiomFoundation/axiom-foundation.org.git",
    "directory": "packages/ui"
  },
  "homepage": "https://axiom-foundation.org",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.1.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "~6.0.3",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json && mkdir -p dist/styles && cp src/styles/tokens.css dist/styles/tokens.css",
    "pack:check": "npm pack --dry-run",
    "prepack": "bun run build",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
